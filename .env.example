# ---- server (src/index.ts) ----
PORT=8787                     # HTTP port: MCP at /mcp, viz at /
DB_PATH=thoughtful.db         # local Turso file
GRACE_MS=10000                # auto-end grace after the last agent disconnects

# ---- embeddings (src/embeddings.ts) — pinned per Namespace ----
EMBED_PROVIDER=qwen           # qwen (default, local ONNX) | minimax (API) | local (lexical dev stub)
QWEN_DTYPE=q8                 # fp32 | fp16 | q8 — Qwen ONNX quantization
#MINIMAX_API_KEY=             # required for EMBED_PROVIDER=minimax
#MINIMAX_GROUP_ID=            # required for EMBED_PROVIDER=minimax

# ---- distiller (src/distiller.ts, separate process) ----
MCP_URL=http://localhost:8787/mcp
#HTTP_BASE=                   # defaults to MCP_URL minus /mcp
DISTILL_NAMESPACE=distilled   # namespace facts are distilled into
SUMMARIZER=heuristic          # heuristic (offline default) | minimax (generative)
#MINIMAX_MODEL=MiniMax-Text-01
